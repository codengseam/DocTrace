# 大模型 API Key（用于调用 Alibaba DashScope Qwen 系列模型）
# 示例：sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DASHSCOPE_API_KEY=

# Obsidian Vault 的本地绝对路径
# 示例：/Users/yourname/Documents/Obsidian Vault
OBSIDIAN_VAULT_PATH=

# 可选：Web 搜索 API Key（Tavily）
# 用于增强资料检索能力，不填则依赖可信域与内置来源
TAVILY_API_KEY=

# 可选：Web 搜索 API Key（Serper）
# Tavily 与 Serper 二选一或同时配置均可
SERPER_API_KEY=
